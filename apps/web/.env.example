# Configuração do Supabase — copie este arquivo para ".env" e preencha com os valores reais do seu projeto.
# Painel: https://supabase.com/dashboard/project/_/settings/api

# Project URL (Settings > API > Project URL)
VITE_SUPABASE_URL=

# Anon public key (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=

# --- Feature flags (opcional; defaults em src/config/AppConfig.ts) ---
# VITE_FF_OPENAI=false
# VITE_FF_OPEN_FINANCE=true
# VITE_FF_INVESTMENTS=true
# VITE_FF_NOTIFICATIONS=false

# Provider Open Finance pretendido: mock | pluggy (pluggy só após integração real)
# VITE_OF_PROVIDER=mock
