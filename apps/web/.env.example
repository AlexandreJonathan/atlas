# Configuração do Supabase — copie este arquivo para ".env" e preencha com os valores reais do seu projeto.
# Painel: https://supabase.com/dashboard/project/_/settings/api

# Project URL (Settings > API > Project URL)
VITE_SUPABASE_URL=

# Anon public key (Settings > API > Project API keys > anon public)
VITE_SUPABASE_ANON_KEY=

# --- Feature flags (opcional; defaults em src/config/AppConfig.ts) ---
# Liga o OpenAIProvider no chat da Atlas IA (requer Edge Function + secret no Supabase).
# VITE_FF_OPENAI=true
# VITE_FF_OPEN_FINANCE=true
# VITE_FF_INVESTMENTS=true
# VITE_FF_NOTIFICATIONS=false

# Provider Open Finance: mock (default) | pluggy (stub drop-in — catálogo vazio até integração HTTP)
# VITE_OF_PROVIDER=mock

# Sentry (opcional). Sem DSN o SDK não carrega.
# VITE_SENTRY_DSN=https://...@o....ingest.sentry.io/...

# NUNCA coloque OPENAI_API_KEY neste arquivo / no front-end.
# Configure no Supabase: `supabase secrets set OPENAI_API_KEY=sk-...`
# Opcional no Edge: OPENAI_MODEL=gpt-4.1-mini
# Rate limit / CORS na Edge (secrets): AI_RATE_LIMIT_USER, AI_RATE_LIMIT_IP, AI_RATE_WINDOW_MS, ALLOWED_ORIGINS
