# Configuração do Supabase — copie para ".env.local" e preencha.
# Painel: https://supabase.com/dashboard/project/_/settings/api
# Guia Alpha: docs/alpha-deploy.md
# Validador: node scripts/validate-alpha-env.mjs

# Project URL (Settings > API > Project URL) — deve resolver DNS
VITE_SUPABASE_URL=

# Anon / publishable key (Settings > API) — NUNCA service_role
VITE_SUPABASE_ANON_KEY=

# --- Alpha privado (recomendado) ---
# Liga o chat OpenAI (requer Edge atlas-ai-chat + secret OPENAI_API_KEY)
VITE_FF_OPENAI=true

# Sentry — obrigatório para Alpha de qualidade (erros + tag request_id)
VITE_SENTRY_DSN=

# --- Feature flags adicionais (defaults em src/config/AppConfig.ts) ---
# VITE_FF_OPEN_FINANCE=true
# VITE_FF_INVESTMENTS=true
# VITE_FF_NOTIFICATIONS=false
# Smart Goals (default true)
# VITE_FF_SMART_GOALS=true
# Budget Planner (default true)
# VITE_FF_BUDGET_PLANNER=true
# Financial Planner (default true)
# VITE_FF_FINANCIAL_PLANNER=true
# Atlas Intelligence v2 RecommendationEngine (default true)
# VITE_FF_ATLAS_INTELLIGENCE_V2=true

# --- Providers ---
# mock (default Alpha sem OF real) | pluggy (exige Edge pluggy-proxy + secrets)
VITE_FINANCIAL_DATA_PROVIDER=mock
VITE_OF_PROVIDER=mock
# Para Open Finance real:
# VITE_FINANCIAL_DATA_PROVIDER=pluggy
# VITE_OF_PROVIDER=pluggy

# NUNCA no front:
# OPENAI_API_KEY, PLUGGY_CLIENT_ID, PLUGGY_CLIENT_SECRET, ALLOWED_ORIGINS
# → npx supabase secrets set ...
